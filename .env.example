# ADAGAMES V4.5 Configuration Example
# Rename this file to .env to use it

# Server host (0.0.0.0 for public/LAN access, 127.0.0.1 for local only)
HOST=0.0.0.0

# Server port
PORT=8000

# Directory where data.json and users.json will be stored
# DATA_DIR=./data

# Debug mode (enables auto-reload)
DEBUG=False
